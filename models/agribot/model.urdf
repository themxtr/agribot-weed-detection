<?xml version="1.0"?>
<robot name="agribot">
<!--Main chassis-->
	<link name="base_link">
	<visual>
	<geometry><box size="0.6 0.4 0.15"/></geometry>
	<material name="green"><color rgba="0.1 0.6 0.1 1"/></material>
	</visual>
	<collision><geometry><box size="0.6 0.4 0.15"/></geometry></collision>
	<inertial><mass value="10"/>
	<inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
	</inertial>
	</link>
<!--Camera housing-->
	<link name="camera_link">
	<visual>
	<geometry><box size="0.05 0.05 0.05"/></geometry>
	<material name="black"><color rgba="0 0 0 1"/></material>
	</visual>
	</link>
<!--Mount camera at front-top of robot, angled slightly down-->
	<joint name="camera_joint" type="fixed">
	<parent link="base_link"/>
	<child link="camera_link"/>
	<origin xyz="0.3 0 0.15" rpy="0 0.3 0"/>
	</joint>
<!--Gazebo camera sensor plugin-->
	<gazebo reference="camera_link">
	<sensor type="camera" name="camera">
	<update_rate>30</update_rate>
	<camera>
	<horizontal_fov>1.3962634</horizontal_fov>
	<image>
	<width>640</width>
	<height>480</height>
	<format>R8G8B8</format>
	</image>
	<clip><near>0.1</near><far>100</far></clip>
	</camera>
<plugin name="camera_ctrl" filename="libgazebo_ros_camera.so">
<ros>
<remapping>image_raw:=/camera/image_raw</remapping>
</ros>
</plugin>
</sensor>
</gazebo>
</robot>
