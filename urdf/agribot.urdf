<?xml version="1.0"?>
<robot name="agribot">

  <link name="base_link">
    <visual>
      <geometry><box size="0.6 0.4 0.15"/></geometry>
      <material name="green">
        <color rgba="0.1 0.6 0.1 1"/>
      </material>
    </visual>
  </link>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.3 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="sprayer_link">
    <visual>
      <geometry><cylinder radius="0.02" length="0.1"/></geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
  </link>

  <joint name="sprayer_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sprayer_link"/>
    <origin xyz="0 0 -0.1" rpy="0 0 0"/>
  </joint>

</robot>
